                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                    </svg>
                    <p class="text-stone-500 dark:text-gray-400 text-sm font-medium">No image available</p>
                </div>
            </div>
        `;
    }
    
    contentHTML += '</div>';
    } // end showGraveSection

    if (data.registerImage) {
        const pathParts = window.location.pathname.split('/').filter(p => p);
        const basePath = pathParts.length > 1 ? '/' + pathParts[0] : '';
        const regPath = `${basePath}/assets/imgs/register/${data.registerImage}`;
        const regPlaceholderId = `reg-placeholder-${Date.now()}-${Math.random().toString(36).substr(2, 9)}`;
        const regLightboxTitle = (escapeHtml(data.fullName) || 'Parish register') + ` — Register page ${escapeHtml(data.registerPage)}`;
        contentHTML += `
            <div class="mb-4 border-b border-stone-200 dark:border-gray-600 pb-4">
                <h3 class="text-lg font-semibold mb-2 text-stone-800 dark:text-white">Parish Register — Page ${data.registerPage}</h3>
                <div class="relative">
                    <img src="${regPath}" loading="lazy"
                         alt="Parish register page ${data.registerPage}"
                         class="w-full max-w-lg mx-auto rounded-lg shadow-lg border border-stone-300 dark:border-gray-600 cursor-zoom-in"
                         onclick="openImageLightbox(this.src, '${regLightboxTitle.replace(/'/g, "\\'")}', this.alt)"
                         onerror="this.style.display='none'; document.getElementById('${regPlaceholderId}').style.display='flex';">
                    <div id="${regPlaceholderId}" class="w-full max-w-lg mx-auto rounded-lg shadow-lg border border-stone-300 dark:border-gray-600 bg-stone-100 dark:bg-gray-700 items-center justify-center aspect-[4/3] hidden">
                        <div class="text-center p-8">
                            <p class="text-stone-500 dark:text-gray-400 text-sm font-medium">Register image unavailable</p>
                        </div>
                    </div>
                </div>
                <p class="text-xs text-stone-500 dark:text-gray-400 mt-2 text-center">Original handwritten entry — page ${data.registerPage} of 16</p>
            </div>
        `;
    }

    // Display all data fields - Basic Information Section
    contentHTML += '<div class="border-b border-stone-200 dark:border-gray-600 pb-3"><h3 class="text-lg font-semibold mb-2 text-stone-800 dark:text-white">Basic Information</h3>';
    
    if (data.rowCode && data.rowCode.trim()) {
        contentHTML += `<div class="mb-2"><strong>Row Code:</strong> <span class="inline-block px-2 py-1 rounded font-semibold text-stone-800" style="background-color: ${getRowCodeColor(data.rowCode)};">${escapeHtml(data.rowCode)}</span></div>`;
    }
    
    if (escapeHtml(data.graveCode)) {
        contentHTML += `<div class="mb-2"><strong>Grave Code:</strong> ${escapeHtml(data.graveCode)}</div>`;
    }
    
    if (escapeHtml(data.plotCode)) {
        contentHTML += `<div class="mb-2"><strong>Plot Code:</strong> ${escapeHtml(data.plotCode)}</div>`;
    }
    
    if (escapeHtml(data.lastName)) {
        contentHTML += `<div class="mb-2"><strong>Last Name:</strong> ${escapeHtml(data.lastName)}</div>`;
    }
    
    if (escapeHtml(data.firstName)) {
        contentHTML += `<div class="mb-2"><strong>First Name:</strong> ${escapeHtml(data.firstName)}</div>`;
    }
    
    if (data.fullName && data.fullName !== 'Unknown') {
        contentHTML += `<div class="mb-2"><strong>Full Name:</strong> ${escapeHtml(data.fullName)}</div>`;
    }
    
    if (escapeHtml(data.age)) {
        contentHTML += `<div class="mb-2"><strong>Age:</strong> ${escapeHtml(data.age)}</div>`;
    }
    
    if (data.deathDate && data.deathDate !== 'Awaited' && data.deathDate !== 'Unknown' && data.deathDate.trim()) {
        contentHTML += `<div class="mb-2"><strong>Death Date:</strong> ${escapeHtml(data.deathDate)}</div>`;
    } else {
        contentHTML += `<div class="mb-2"><strong>Death Date:</strong> <span class="text-stone-400">Unknown</span></div>`;
    }
    
    if (escapeHtml(data.burialDate)) {
        contentHTML += `<div class="mb-2"><strong>Burial Date:</strong> ${escapeHtml(data.burialDate)}</div>`;
    }
    
    if (escapeHtml(data.months)) {
        contentHTML += `<div class="mb-2"><strong>Months:</strong> ${escapeHtml(data.months)}</div>`;
    }
    
    if (escapeHtml(data.status)) {
        contentHTML += `<div class="mb-2"><strong>Status:</strong> ${escapeHtml(data.status)}</div>`;
    }
    
    if (escapeHtml(data.occupation)) {
        contentHTML += `<div class="mb-2"><strong>Occupation:</strong> ${escapeHtml(data.occupation)}</div>`;
    }
    
    if (escapeHtml(data.address)) {
        contentHTML += `<div class="mb-2"><strong>Address:</strong> ${escapeHtml(data.address)}</div>`;
    }
    
    if (escapeHtml(data.witness)) {
        contentHTML += `<div class="mb-2"><strong>Witness:</strong> ${escapeHtml(data.witness)}</div>`;
    }
    
    contentHTML += '</div>';
    
    // Headstone Information Section
    if (escapeHtml(data.namesOnHeadstone) || escapeHtml(data.stoneInscription) || escapeHtml(data.stoneDesign) || escapeHtml(data.headstoneShape)) {
        contentHTML += '<div class="border-b border-stone-200 dark:border-gray-600 pb-3 mt-4"><h3 class="text-lg font-semibold mb-2 text-stone-800 dark:text-white">Headstone Information</h3>';
        
        if (escapeHtml(data.namesOnHeadstone)) {
            contentHTML += `<div class="mb-2"><strong>Names on Headstone:</strong> ${escapeHtml(data.namesOnHeadstone)}</div>`;
        }
        
        if (escapeHtml(data.stoneInscription)) {
            contentHTML += `<div class="mb-2"><strong>Stone Inscription:</strong> <span class="italic">${escapeHtml(data.stoneInscription)}</span></div>`;
        }
        
        if (escapeHtml(data.stoneDesign)) {
            contentHTML += `<div class="mb-2"><strong>Stone Design:</strong> ${escapeHtml(data.stoneDesign)}</div>`;
        }
        
        if (escapeHtml(data.headstoneShape)) {
            contentHTML += `<div class="mb-2"><strong>Headstone Shape:</strong> ${escapeHtml(data.headstoneShape)}</div>`;
        }
        
        contentHTML += '</div>';
    }
    
    // Comments Section
    if (escapeHtml(data.comments)) {
        contentHTML += '<div class="mt-4"><h3 class="text-lg font-semibold mb-2 text-stone-800 dark:text-white">Additional Notes</h3>';
        contentHTML += `<div class="mb-2 text-stone-700 dark:text-gray-300 whitespace-pre-wrap">${escapeHtml(data.comments)}</div>`;
        contentHTML += '</div>';
    }
    
    contentHTML += '</div>';
    
    content.innerHTML = contentHTML;
    modal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    
    // Scroll modal content to top when navigating
    // Find the scrollable content container (the div with overflow-y-auto)
    const modalContainer = modal.querySelector('.bg-white, .dark\\:bg-gray-800');
    if (modalContainer) {
        const scrollableContent = modalContainer.querySelector('.overflow-y-auto');
        if (scrollableContent) {
            scrollableContent.scrollTop = 0;
        }
    }
}

// Helper function to get row code color
function getRowCodeColor(rowCode) {
    const colors = {
        'A': 'rgb(255, 255, 153)',
        'B': 'rgb(255, 153, 255)',
        'C': 'rgb(97, 203, 243)',
        'D': 'rgb(0, 176, 240)',
        'E': 'rgb(255, 192, 0)',
        'F': 'rgb(0, 204, 102)',
        'G': 'rgb(255, 0, 0)',
        'H': 'rgb(153, 153, 255)',
        'I': 'rgb(0, 204, 0)',
        'J': 'rgb(255, 153, 51)',
        'K': 'rgb(112, 168, 224)',
        'L': 'rgb(255, 204, 255)',
        'M': 'rgb(255, 255, 0)',
        'N': 'rgb(146, 208, 80)',
        'O': 'rgb(153, 102, 255)',
        'P': 'rgb(0, 176, 240)',
        'Q': 'rgb(60, 125, 34)',
        'R': 'rgb(153, 102, 255)',
        'S': 'rgb(146, 208, 80)',
        'T': 'rgb(255, 51, 153)',
        'U': 'rgb(255, 153, 51)',
        'V': 'rgb(0, 176, 240)'
    };
    return colors[rowCode.toUpperCase()] || 'transparent';
}

function closeBurialModal() {
    const modal = document.getElementById('burialModal');
    modal.classList.add('hidden');
    document.body.style.overflow = 'auto';
}

function openImageLightbox(src, title, alt) {
    const lb = document.getElementById('imageLightbox');
    const img = document.getElementById('imageLightboxImg');
    img.src = src;
    img.alt = alt || title || '';
    document.getElementById('imageLightboxTitle').textContent = title || '';
    lb.classList.remove('hidden');
}

function closeImageLightbox(e) {
    if (e && e.target !== e.currentTarget) return;
    const lb = document.getElementById('imageLightbox');
    lb.classList.add('hidden');
    document.getElementById('imageLightboxImg').src = '';
}

function isImageLightboxOpen() {
    return !document.getElementById('imageLightbox').classList.contains('hidden');
}

// Close modal when clicking outside
document.getElementById('burialModal').addEventListener('click', function(e) {
    if (e.target === this) {
        closeBurialModal();
    }
});

// Close modal with escape key and navigate with arrow keys
document.addEventListener('keydown', function(e) {
    const modal = document.getElementById('burialModal');
    const isModalOpen = !modal.classList.contains('hidden');

    if (e.key === 'Escape' && isImageLightboxOpen()) {
        // Lightbox takes precedence over the burial modal
        closeImageLightbox();
    } else if (e.key === 'Escape' && isModalOpen) {
        closeBurialModal();
    } else if (e.key === 'Escape' && isFilterPanelOpen()) {
        setFilterPanelOpen(false);
    } else if (isModalOpen && !isImageLightboxOpen() && (e.key === 'ArrowLeft' || e.key === 'ArrowRight')) {
        // Prevent default scrolling behavior
        e.preventDefault();

        if (e.key === 'ArrowLeft') {
            navigateBurial(-1);
        } else if (e.key === 'ArrowRight') {
            navigateBurial(1);
        }
    }
});

// =====================================================================
// Mobile toolbar: sort dispatch, filter panel, and URL-state contract.
// URL params: ?sort=az|za|date_old|date_new|row  ?missing=1  ?q=<string>
// =====================================================================

// Maps the (column, direction) pair currently in `currentSort` to one of the
// five toolbar modes, or null for column-header sorts that aren't bookmarkable.
function currentSortMode() {
    const c = currentSort.column;
    const d = currentSort.direction;
    if (c === 'name') return d === 'asc' ? 'az' : 'za';
    if (c === 'date') return d === 'asc' ? 'date_old' : 'date_new';
    if (c === 'row') return 'row';
    return null;
}

function syncMobileSortSelect() {
    const select = document.getElementById('sortSelectMobile');
    if (!select) return;
    select.value = currentSortMode() || '';
}

// Called at the end of every toolbar-driven sort (sortAlphabetical/Date/Row).
// Keeps the mobile select and the URL in step with whatever just happened.
function afterToolbarSort() {
    syncMobileSortSelect();
    writeUrlState({ sort: currentSortMode() });
}

// Dispatched from the mobile <select> — explicit-direction equivalents of the
// desktop sort buttons. Empty value (placeholder) is a no-op.
function applySort(mode) {
    switch (mode) {
        case 'az':       sortAlphabetical('asc');  break;
        case 'za':       sortAlphabetical('desc'); break;
        case 'date_old': sortByDate('asc');        break;
        case 'date_new': sortByDate('desc');       break;
        case 'row':      sortByRow('asc');         break;
        // default: do nothing
    }
}

// ---- Filter panel ---------------------------------------------------

function isFilterPanelOpen() {
    const panel = document.getElementById('filterPanelMobile');
    return !!panel && !panel.classList.contains('hidden');
}

function setFilterPanelOpen(open) {
    const panel = document.getElementById('filterPanelMobile');
    const btn = document.getElementById('filterBtnMobile');
    if (!panel || !btn) return;
    panel.classList.toggle('hidden', !open);
    btn.setAttribute('aria-expanded', open ? 'true' : 'false');
    if (open) {
        const firstControl = panel.querySelector('input, button, select, textarea, [tabindex]');
        if (firstControl) firstControl.focus();
    } else {
        btn.focus();
    }
}

function toggleFilterPanel() {
    setFilterPanelOpen(!isFilterPanelOpen());
}

// Outside-tap dismissal for the filter panel.
document.addEventListener('click', function(e) {
    if (!isFilterPanelOpen()) return;
    const panel = document.getElementById('filterPanelMobile');
    const btn = document.getElementById('filterBtnMobile');
    if (panel.contains(e.target) || (btn && btn.contains(e.target))) return;
    setFilterPanelOpen(false);
});

// ---- URL state ------------------------------------------------------

let _skipUrlWrites = false;

function readUrlState() {
    const params = new URLSearchParams(window.location.search);
    const sort = params.get('sort');
    const validSorts = ['az', 'za', 'date_old', 'date_new', 'row'];
    return {
        sort: validSorts.includes(sort) ? sort : null,
        missing: params.get('missing') === '1',
        q: params.get('q') || ''
    };
}

function writeUrlState(patch) {
    if (_skipUrlWrites) return;
    const params = new URLSearchParams(window.location.search);
    Object.keys(patch).forEach(k => {
        const v = patch[k];
        if (v === null || v === undefined || v === '' || v === false) {
            params.delete(k);
        } else {
            params.set(k, v);
        }
    });
    const qs = params.toString();
    const newUrl = window.location.pathname + (qs ? '?' + qs : '') + window.location.hash;
    window.history.replaceState(null, '', newUrl);
}

function initToolbar() {
    const state = readUrlState();
    _skipUrlWrites = true;
    try {
        if (state.q) {
            const desktopInput = document.getElementById('searchInput');
            const mobileInput = document.getElementById('searchInputMobile');
            if (desktopInput) desktopInput.value = state.q;
            if (mobileInput) mobileInput.value = state.q;
            const dBtn = document.getElementById('clearSearchBtn');
            const mBtn = document.getElementById('clearSearchBtnMobile');
            if (dBtn) dBtn.classList.remove('hidden');
            if (mBtn) mBtn.classList.remove('hidden');
        }
        // Only call setMissingPhotos when actually turning the filter on — calling
        // it with `false` would force a sortByRow on every default load and surprise
        // users who didn't ask for any sort.
        if (state.missing) {
            setMissingPhotos(true);
        } else if (state.q) {
            // Search-only path: apply visibility + highlight without disturbing order.
            const term = state.q.toLowerCase();
            document.querySelectorAll('.burial-row').forEach(row => {
                row.style.display = rowPassesFilters(row, term) ? '' : 'none';
            });
            applySearchHighlighting();
            updateResultsCount();
        }
        if (state.sort) applySort(state.sort);
    } finally {
        _skipUrlWrites = false;
    }
}
</script>