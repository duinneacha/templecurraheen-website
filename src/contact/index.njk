---
layout: base.njk
title: Contact
description: Get in touch with the Templecurraheen Graveyard Documentation Project — share information, photographs, family stories, or general enquiries.
---

<div class="max-w-2xl mx-auto">
    <h1 class="text-3xl font-serif font-bold text-primary-800 dark:text-purple-300 mb-4">Contact Us</h1>
    <p class="text-stone-600 dark:text-gray-300 mb-8">
        Whether you have a family story to share, a photograph to contribute, information about a burial record, or simply a general enquiry about the graveyard — we'd love to hear from you.
    </p>

    <div class="bg-white dark:bg-gray-800 border border-stone-200 dark:border-gray-700 rounded-lg p-6 sm:p-8 shadow-sm">

        <form id="contact-form" novalidate>
            <div class="space-y-5">

                <div>
                    <label for="name" class="block text-sm font-medium text-stone-700 dark:text-gray-300 mb-1">Name <span class="text-red-600" aria-hidden="true">*</span></label>
                    <input
                        type="text"
                        id="name"
                        name="name"
                        required
                        autocomplete="name"
                        class="w-full px-4 py-2 border border-stone-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-stone-900 dark:text-gray-100 placeholder-stone-400 dark:placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors"
                        placeholder="Your name"
                    >
                </div>

                <div>
                    <label for="email" class="block text-sm font-medium text-stone-700 dark:text-gray-300 mb-1">Email <span class="text-red-600" aria-hidden="true">*</span></label>
                    <input
                        type="email"
                        id="email"
                        name="email"
                        required
                        autocomplete="email"
                        class="w-full px-4 py-2 border border-stone-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-stone-900 dark:text-gray-100 placeholder-stone-400 dark:placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors"
                        placeholder="your@email.com"
                    >
                </div>

                <div>
                    <label for="subject" class="block text-sm font-medium text-stone-700 dark:text-gray-300 mb-1">Subject</label>
                    <input
                        type="text"
                        id="subject"
                        name="subject"
                        autocomplete="off"
                        class="w-full px-4 py-2 border border-stone-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-stone-900 dark:text-gray-100 placeholder-stone-400 dark:placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors"
                        placeholder="e.g. Family history enquiry, Photo contribution…"
                    >
                </div>

                <div>
                    <label for="message" class="block text-sm font-medium text-stone-700 dark:text-gray-300 mb-1">Message <span class="text-red-600" aria-hidden="true">*</span></label>
                    <textarea
                        id="message"
                        name="message"
                        required
                        rows="6"
                        class="w-full px-4 py-2 border border-stone-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-stone-900 dark:text-gray-100 placeholder-stone-400 dark:placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors resize-y"
                        placeholder="Your message…"
                    ></textarea>
                </div>

                <!-- Honeypot — hidden from real users, catches bots -->
                <input type="text" name="_gotcha" class="hidden" tabindex="-1" autocomplete="off">

                <div id="form-error" class="hidden bg-red-50 dark:bg-red-900/30 border border-red-200 dark:border-red-700 rounded-md px-4 py-3 text-red-700 dark:text-red-300 text-sm" role="alert">
                    Something went wrong sending your message. Please try again, or email us directly at <a href="mailto:duinneacha@gmail.com" class="underline">duinneacha@gmail.com</a>.
                </div>

                <button
                    type="submit"
                    id="submit-btn"
                    class="btn btn-primary w-full sm:w-auto"
                >
                    Send Message
                </button>

            </div>
        </form>

        <!-- Success message — shown after successful submission -->
        <div id="form-success" class="hidden text-center py-8">
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-green-100 dark:bg-green-900/40 mb-4">
                <svg class="w-8 h-8 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
            </div>
            <h2 class="text-xl font-serif font-semibold text-stone-800 dark:text-gray-100 mb-2">Thank You!</h2>
            <p class="text-stone-600 dark:text-gray-300">
                Your message has been received. We'll be in touch as soon as we can.
            </p>
        </div>

    </div>
</div>

<script>
    const form = document.getElementById('contact-form');
    const successPanel = document.getElementById('form-success');
    const errorPanel = document.getElementById('form-error');
    const submitBtn = document.getElementById('submit-btn');

    form.addEventListener('submit', async function (e) {
        e.preventDefault();

        if (!form.checkValidity()) {
            form.reportValidity();
            return;
        }

        submitBtn.disabled = true;
        submitBtn.textContent = 'Sending…';
        errorPanel.classList.add('hidden');

        try {
            const res = await fetch('https://formspree.io/f/mgojzlly', {
                method: 'POST',
                body: new FormData(form),
                headers: { 'Accept': 'application/json' }
            });

            if (res.ok) {
                form.classList.add('hidden');
                successPanel.classList.remove('hidden');
            } else {
                errorPanel.classList.remove('hidden');
                submitBtn.disabled = false;
                submitBtn.textContent = 'Send Message';
            }
        } catch (_) {
            errorPanel.classList.remove('hidden');
            submitBtn.disabled = false;
            submitBtn.textContent = 'Send Message';
        }
    });
</script>
